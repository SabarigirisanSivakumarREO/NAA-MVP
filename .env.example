# =============================================================================
# Neural MVP — environment variables
# Copy to `.env` (gitignored) and fill in secrets.
# Reference: PRD.md §6.4 (tech stack), §7.5 (adapters), §8.1 (install workflow).
# Security: never commit `.env`. Secrets via process.env only (Constitution R13).
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Phase 0 local dev
# -----------------------------------------------------------------------------

# Claude Sonnet 4 via @anthropic-ai/sdk — primary LLM (PRD §6.4, F-007).
# Create at console.anthropic.com. Pay-as-you-go; NOT included with Claude Max.
ANTHROPIC_API_KEY=

# Local Postgres 16 + pgvector (docker-compose). Credentials match docker-compose.yml.
POSTGRES_URL=postgresql://neural:neural@localhost:5432/neural

# Valkey (Redis-compatible, OSS-licensed) — BullMQ queue + cache.
REDIS_URL=redis://localhost:6379

# Runtime mode — adapter selectors read this.
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Screenshot + PDF storage (ScreenshotStorage adapter — PRD §7.5)
# dev: local_disk (no signup). prod: r2 (fill block below at Week 11).
# -----------------------------------------------------------------------------

STORAGE_MODE=local_disk
STORAGE_LOCAL_PATH=./.storage

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=neural-prod
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Email notifications (NotificationAdapter — PRD §F-020)
# dev: mailpit (captures locally, never sends). prod: resend.
# -----------------------------------------------------------------------------

EMAIL_MODE=mailpit
EMAIL_FROM=neural@reo.digital
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025

RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Dashboard auth (AuthProvider adapter — fill at Phase 9, F-019)
# -----------------------------------------------------------------------------

CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# Production Redis (Week 11 prod deploy — swap REDIS_URL above)
# -----------------------------------------------------------------------------

UPSTASH_REDIS_URL=

# -----------------------------------------------------------------------------
# Budget + safety caps (PRD §F-021 + Constitution R8). Override only with approval.
# -----------------------------------------------------------------------------

AUDIT_BUDGET_USD=15
PAGE_BUDGET_USD=5
